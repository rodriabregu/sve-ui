{
	"extends": ["@repo/typescript-config/svelte-lib.json", "./.svelte-kit/tsconfig.json"],
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true
	}
	// Path aliases are handled by SvelteKit — see .svelte-kit/tsconfig.json
}
